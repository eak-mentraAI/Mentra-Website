# ===========================================
# Mentra Environment Variables
# ===========================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ===========================================

# ----- Dashboard (dashboard-refactored/) -----

# Required: Session encryption key (use a random 64+ char string)
SESSION_SECRET=

# Required: Login credentials as JSON
# Passwords should be hashed in production (bcrypt recommended)
# Format: {"email":"password_or_hash", ...}
VALID_CREDENTIALS={}

# API keys for external services
HUGGINGFACE_API_KEY=
VLLM_API_KEY=

# vLLM server connection
VLLM_HOST=localhost
VLLM_PORT=8001

# Server config
PORT=4000
NODE_ENV=development
